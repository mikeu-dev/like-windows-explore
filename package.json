{
  "name": "like-windows-explorer",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:api": "bun --cwd packages/api dev",
    "dev:web": "bun --cwd packages/web dev",
    "dev": "bun run --filter '*' dev",
    "build": "bun run --filter '*' build",
    "test": "bun test",
    "test:e2e": "bun --cwd packages/e2e test",
    "format": "prettier --write \"**/*.{ts,vue,json,md,html,css,js}\"",
    "format:check": "prettier --check \"**/*.{ts,vue,json,md,html,css,js}\"",
    "lint": "eslint \"packages/**/*.{ts,vue}\"",
    "check": "bun --cwd packages/api tsc --noEmit && bun --cwd packages/web vue-tsc --noEmit && bun --cwd packages/e2e tsc --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.1",
    "eslint": "^9.4.0",
    "eslint-plugin-vue": "^9.26.0",
    "prettier": "^3.3.0",
    "typescript": "^5.4.5",
    "typescript-eslint": "^7.11.0",
    "vue-tsc": "^2.0.19"
  }
}

